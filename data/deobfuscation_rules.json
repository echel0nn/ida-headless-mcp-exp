{
  "_meta": {
    "description": "Expression rewrite rules for deobfuscation. Pattern/replacement use infix notation with variables (x,y,z) and constants (c1,c2). Engine parses into miasm expression trees.",
    "operators": "+, -, *, /, %, &, |, ^, ~, <<, >>",
    "variables": "x, y, z (match any expression), c1, c2, c3 (match constants)",
    "special": "~x = bitwise NOT, -x = negation"
  },
  "xor_identities": [
    {"name": "hd1", "pattern": "(x | y) - (x & y)", "result": "x ^ y"},
    {"name": "hd2", "pattern": "2 * (x | y) - (x + y)", "result": "x ^ y"},
    {"name": "hd3", "pattern": "(x + y) - 2 * (x & y)", "result": "x ^ y"},
    {"name": "hd4", "pattern": "(x - y) - 2 * (x | ~y) - 2", "result": "x ^ y"},
    {"name": "hd5", "pattern": "x - (2 * (x & y) - y)", "result": "x ^ y"},
    {"name": "mba1", "pattern": "x - (2 * (y & ~(x ^ y)) - y)", "result": "x ^ y"},
    {"name": "mba2", "pattern": "x - (2 * (x & y) - y)", "result": "x ^ y"},
    {"name": "mba3_partial", "pattern": "x - 2 * (x & y)", "result": "(x ^ y) - y"},
    {"name": "factor1", "pattern": "(x & ~y) | (~x & y)", "result": "x ^ y"},
    {"name": "factor2", "pattern": "(~x & y) ^ (x & ~y)", "result": "x ^ y"},
    {"name": "factor3", "pattern": "(x & y) ^ (x | y)", "result": "x ^ y"},
    {"name": "factor4", "pattern": "(x | y) & (~x | ~y)", "result": "x ^ y"},
    {"name": "factor5", "pattern": "(x | y) & ~(x & y)", "result": "x ^ y"},
    {"name": "demorgan", "pattern": "~(~x & ~y) & ~(x & y)", "result": "x ^ y"},
    {"name": "special1", "pattern": "(x - y) + 2 * (~x & y)", "result": "x ^ y"},
    {"name": "special2", "pattern": "x + (0xFE * (x & y)) + y", "result": "x ^ y", "note": "0xFE = mask-2 for the operand size"},
    {"name": "xor1_mba", "pattern": "~x + (2 * x | 2)", "result": "x ^ 1"},
    {"name": "bnot_or", "pattern": "(x & y) | ~(x | y)", "result": "x ^ ~y"},
    {"name": "ollvm1", "pattern": "((x ^ z) & (y ^ ~z)) | ((x ^ ~z) & (y ^ z))", "result": "x ^ y"},
    {"name": "ollvm2", "pattern": "((x ^ z) & (y ^ z)) | ((x ^ ~z) & (y ^ ~z))", "result": "~x ^ y"},
    {"name": "with_bnot", "pattern": "(x & ~y) | (~x & y)", "result": "x ^ y"},
    {"name": "xdu_variant", "pattern": "(x & ~c1) | (~x & c1)", "result": "x ^ c1"}
  ],
  "add_identities": [
    {"name": "mba1", "pattern": "(x | y) + (x & y)", "result": "x + y"},
    {"name": "mba2", "pattern": "(x ^ y) + 2 * (x & y)", "result": "x + y"},
    {"name": "mba3", "pattern": "2 * (x | y) - (x ^ y)", "result": "x + y"},
    {"name": "mba4", "pattern": "(x & y) + (x | y)", "result": "x + y"},
    {"name": "mba5", "pattern": "2 * (x & y) + (x ^ y)", "result": "x + y"},
    {"name": "mba6", "pattern": "(x | y) - (~x & y)", "result": "x"},
    {"name": "mba7", "pattern": "(x ^ y) + 2 * (x & y)", "result": "x + y"},
    {"name": "zero_add", "pattern": "x + 0", "result": "x"},
    {"name": "cancel", "pattern": "x + (-x)", "result": "0"},
    {"name": "neg_sub", "pattern": "x + (~y) + 1", "result": "x - y"},
    {"name": "double", "pattern": "x + x", "result": "x * 2"},
    {"name": "bnot_add", "pattern": "(x ^ c1) + (2 * (x & c1) + 1)", "result": "x - ~c1"}
  ],
  "sub_identities": [
    {"name": "cancel", "pattern": "x - x", "result": "0"},
    {"name": "zero", "pattern": "x - 0", "result": "x"},
    {"name": "neg", "pattern": "0 - x", "result": "-x"},
    {"name": "mba1", "pattern": "(x | y) - (x ^ y)", "result": "x & y"},
    {"name": "mba2", "pattern": "(x + y) - (x | y)", "result": "x & y"},
    {"name": "mba3", "pattern": "(x | y) - (~x & y)", "result": "x"},
    {"name": "mba4", "pattern": "x - (x & y)", "result": "x & ~y"},
    {"name": "to_xor", "pattern": "(x | y) - (x & y)", "result": "x ^ y"},
    {"name": "neg_to_add", "pattern": "x - (-y)", "result": "x + y"}
  ],
  "and_identities": [
    {"name": "idempotent", "pattern": "x & x", "result": "x"},
    {"name": "zero", "pattern": "x & 0", "result": "0"},
    {"name": "identity", "pattern": "x & ~0", "result": "x"},
    {"name": "absorb", "pattern": "(x | c1) & c2", "result": "x & c2", "constraint": "c1 & c2 == c2"},
    {"name": "demorgan", "pattern": "~(~x | ~y)", "result": "x & y"},
    {"name": "mba1", "pattern": "(x + y) - (x | y)", "result": "x & y"},
    {"name": "mba2", "pattern": "(x | y) - (x ^ y)", "result": "x & y"},
    {"name": "mba3", "pattern": "~(~x | ~y)", "result": "x & y"},
    {"name": "mask_shift", "pattern": "(x >> c1) & 1", "result": "(x >> c1) & 1", "note": "bit extraction, keep as-is"},
    {"name": "clear_bits", "pattern": "x & ~(x & y)", "result": "x & ~y"},
    {"name": "distribute", "pattern": "(x & c1) & c2", "result": "x & (c1 & c2)"}
  ],
  "or_identities": [
    {"name": "idempotent", "pattern": "x | x", "result": "x"},
    {"name": "zero", "pattern": "x | 0", "result": "x"},
    {"name": "full", "pattern": "x | ~0", "result": "~0"},
    {"name": "demorgan", "pattern": "~(~x & ~y)", "result": "x | y"},
    {"name": "distribute1", "pattern": "(x & c1) | (x & c2)", "result": "x & (c1 | c2)"},
    {"name": "distribute2", "pattern": "(x | c1) | c2", "result": "x | (c1 | c2)"},
    {"name": "absorb", "pattern": "x | (x & y)", "result": "x"},
    {"name": "complement", "pattern": "x | ~x", "result": "~0"},
    {"name": "mba1", "pattern": "(x & y) | (x ^ y)", "result": "x | y"},
    {"name": "mba2", "pattern": "(x + y) - (x & y)", "result": "x | y"}
  ],
  "mul_identities": [
    {"name": "zero", "pattern": "x * 0", "result": "0"},
    {"name": "identity", "pattern": "x * 1", "result": "x"},
    {"name": "negate", "pattern": "x * ~0", "result": "-x"},
    {"name": "double", "pattern": "x * 2", "result": "x + x"},
    {"name": "shift2", "pattern": "x * 2", "result": "x << 1"},
    {"name": "shift4", "pattern": "x * 4", "result": "x << 2"},
    {"name": "shift8", "pattern": "x * 8", "result": "x << 3"},
    {"name": "neg_mul", "pattern": "(-x) * (-y)", "result": "x * y"}
  ],
  "bnot_identities": [
    {"name": "double", "pattern": "~~x", "result": "x"},
    {"name": "demorgan_and", "pattern": "~(x & y)", "result": "~x | ~y"},
    {"name": "demorgan_or", "pattern": "~(x | y)", "result": "~x & ~y"},
    {"name": "xor_mask", "pattern": "~x", "result": "x ^ ~0"},
    {"name": "neg_rel", "pattern": "~x", "result": "-(x + 1)"},
    {"name": "bnot_xor", "pattern": "~(x ^ y)", "result": "(x & y) | (~x & ~y)"},
    {"name": "bnot_and_or", "pattern": "~(x & c1) & c2", "result": "(~x | ~c1) & c2"},
    {"name": "bnot_or_and", "pattern": "~(x | c1) | c2", "result": "(~x & ~c1) | c2"},
    {"name": "triple_bnot", "pattern": "~~~x", "result": "~x"},
    {"name": "xor_double_bnot", "pattern": "~x ^ ~y", "result": "x ^ y"}
  ],
  "neg_identities": [
    {"name": "double", "pattern": "--x", "result": "x"},
    {"name": "flip", "pattern": "-(x - y)", "result": "y - x"},
    {"name": "to_bnot", "pattern": "-x", "result": "~x + 1"},
    {"name": "from_bnot", "pattern": "~x + 1", "result": "-x"},
    {"name": "neg_add", "pattern": "-(x + y)", "result": "-x - y"},
    {"name": "neg_neg_mul", "pattern": "-(-x)", "result": "x"}
  ],
  "constant_fold": [
    {"name": "add", "pattern": "c1 + c2", "result": "c1 + c2", "action": "evaluate"},
    {"name": "sub", "pattern": "c1 - c2", "result": "c1 - c2", "action": "evaluate"},
    {"name": "mul", "pattern": "c1 * c2", "result": "c1 * c2", "action": "evaluate"},
    {"name": "and", "pattern": "c1 & c2", "result": "c1 & c2", "action": "evaluate"},
    {"name": "or", "pattern": "c1 | c2", "result": "c1 | c2", "action": "evaluate"},
    {"name": "xor", "pattern": "c1 ^ c2", "result": "c1 ^ c2", "action": "evaluate"},
    {"name": "shl", "pattern": "c1 << c2", "result": "c1 << c2", "action": "evaluate"},
    {"name": "shr", "pattern": "c1 >> c2", "result": "c1 >> c2", "action": "evaluate"},
    {"name": "neg", "pattern": "-c1", "result": "-c1", "action": "evaluate"},
    {"name": "bnot", "pattern": "~c1", "result": "~c1", "action": "evaluate"},
    {"name": "nested_add", "pattern": "(x + c1) + c2", "result": "x + (c1 + c2)", "action": "fold_constants"},
    {"name": "nested_sub", "pattern": "(x - c1) - c2", "result": "x - (c1 + c2)", "action": "fold_constants"},
    {"name": "nested_xor", "pattern": "(x ^ c1) ^ c2", "result": "x ^ (c1 ^ c2)", "action": "fold_constants"},
    {"name": "nested_and", "pattern": "(x & c1) & c2", "result": "x & (c1 & c2)", "action": "fold_constants"},
    {"name": "nested_or", "pattern": "(x | c1) | c2", "result": "x | (c1 | c2)", "action": "fold_constants"}
  ],
  "opaque_predicates": [
    {"name": "jnz1", "pattern": "-(~x & 1) != x", "always_true": true, "proof": "-(~x&1) = x&1 or -(1-lsb(x)), never equals x for any x"},
    {"name": "jnz2", "pattern": "(~x | 1) != 0", "always_true": true, "proof": "~x|1 has bit 0 set, so never 0"},
    {"name": "jnz3", "pattern": "(x ^ c1) ^ (x & c2) != 0", "always_true": true, "constraint": "c1 & c2 != 0", "proof": "bits in c1&c2 survive the XOR"},
    {"name": "jnz4", "pattern": "(3 - x) != x", "always_true": true, "proof": "3-x==x only if x=1.5, impossible for integers"},
    {"name": "jnz5", "pattern": "(3 - x) ^ x != 0", "always_true": true, "proof": "odd constant minus x XOR x always nonzero"},
    {"name": "jnz6", "pattern": "~(3 - x) ^ ~x != 0", "always_true": true, "proof": "same as jnz5 with double complement"},
    {"name": "jnz7", "pattern": "(x & c1) != c2", "always_true": true, "constraint": "c1 & c2 != c2", "proof": "masking x with c1 can never produce c2 if c2 has bits outside c1"},
    {"name": "jnz8", "pattern": "(x | c1) != c2", "always_true": true, "constraint": "c1 & c2 != c1", "proof": "OR with c1 always sets c1's bits, can't equal c2 if c2 lacks them"},
    {"name": "jb1", "pattern": "zext(x & 1) < 2", "always_true": true, "proof": "x&1 is 0 or 1, always < 2"},
    {"name": "jae1", "pattern": "(x & c1) >= c2", "always_false": true, "constraint": "c1 < c2", "proof": "masking with c1 caps the value below c2"},
    {"name": "lcg", "pattern": "y == (A * x % m + K) % m", "always_true": true, "constraint": "x == y at init, same LCG applied to both", "proof": "identical transforms on equal inputs produce equal outputs"},
    {"name": "quadratic", "pattern": "x * (x + 1) % 2 == 0", "always_true": true, "proof": "consecutive integers: one is always even"},
    {"name": "bitmanip_shl_and", "pattern": "(x << c1) & c2 == 0", "always_true": true, "constraint": "c2 < (1 << c1)", "proof": "shifting left by c1 clears bottom c1 bits, AND with c2 that fits in those bits = 0"},
    {"name": "bitmanip_and_and", "pattern": "(x & c1) & c2 == 0", "always_true": true, "constraint": "c1 & c2 == 0", "proof": "disjoint masks"}
  ],
  "predicate_simplifications": [
    {"name": "pred_setnz1", "pattern": "(x | c1) != c2", "result": "1", "constraint": "(c1 | c2) != c2"},
    {"name": "pred_setnz2", "pattern": "(x & c1) != c2", "result": "1", "constraint": "(c1 & c2) != c2"},
    {"name": "pred_setnz3", "pattern": "(x | 2) + (x ^ 2) != 0", "result": "1"},
    {"name": "pred_setnz4", "pattern": "(c1 - x) ^ x != 0", "result": "1", "constraint": "c1 % 2 == 1"},
    {"name": "pred_setnz5", "pattern": "-(~x & 1) != x", "result": "1"},
    {"name": "pred_setnz6", "pattern": "((x + c1) + ((x + c2) & 1)) != 0", "result": "1", "constraint": "(c2 - c1) & 1 == 1"},
    {"name": "pred_setz1", "pattern": "x % 2 == 0", "result": "1", "constraint": "x is always even (e.g. x*(x+1))"},
    {"name": "pred_setz2", "pattern": "x & 1 == 0", "result": "1", "constraint": "x is always even"}
  ],
  "smt_verification": [
    {"name": "setz_generic", "description": "For any setz(a,b): simplify a-b, if result is 0 -> always true, if nonzero -> always false. Use binbit/miasm simplifier."},
    {"name": "setnz_generic", "description": "For any setnz(a,b): simplify a-b, if result is 0 -> always false, if nonzero -> always true."},
    {"name": "lnot_generic", "description": "For lnot(a): simplify a, if result is 0 -> lnot=1, if nonzero -> lnot=0."},
    {"name": "smod2_generic", "description": "For a%2: simplify a, check if always even (result=0) or always odd (result=1)."}
  ]
}
